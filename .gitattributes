# Normalize all text files to LF in the repo, regardless of contributor OS /
# git core.autocrlf. Stops the CRLF<->LF churn (Windows + WSL + macOS/Linux).
* text=auto eol=lf

# Explicit for the formats we use (belt and suspenders).
*.sol   text eol=lf
*.ts    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.lock  text eol=lf

# Binaries — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
