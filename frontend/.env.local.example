# Wordlelo frontend — copy to .env.local and adjust.

# Base URL of the @wordlelo/be backend (Fastify). Used only when the real
# backend is enabled below. Example for local dev:
NEXT_PUBLIC_BE_URL=http://localhost:3001

# "true" calls the real backend; anything else uses the in-app mock (default).
# Flip to "true" once the backend is running and reachable (CORS must allow this origin).
NEXT_PUBLIC_USE_REAL_BE=false
