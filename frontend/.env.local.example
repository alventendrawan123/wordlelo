# Wordlelo frontend — copy to .env.local and adjust.

# Base URL of the @wordlelo/be backend. The live deployment:
NEXT_PUBLIC_BE_URL=https://wordlelobe-production.up.railway.app

# "true" calls the real backend; anything else uses the in-app mock.
# The backend is live, so "true" plays the real daily puzzle and can settle on Celo.
NEXT_PUBLIC_USE_REAL_BE=true
