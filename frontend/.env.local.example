# Wordlelo frontend — copy to .env.local and adjust.

# Backend origin. SERVER-ONLY (no NEXT_PUBLIC_ prefix) — it is used by the
# next.config rewrite to proxy /api/v1/*, so the browser never sees this URL
# and there is no cross-origin request. The live deployment:
BE_URL=https://wordlelobe-production.up.railway.app

# "true" calls the real backend (through the same-origin /api/v1 proxy);
# anything else uses the in-app mock.
NEXT_PUBLIC_USE_REAL_BE=true
