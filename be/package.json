{
  "name": "@wordlelo/be",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Wordlelo backend — daily-word authority + SETTLER attestation signer for the Celo game",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "commit:day": "tsx src/scripts/commit.ts",
    "commit:buffer": "node dist/scripts/commit-buffer.js",
    "commit:buffer:dev": "tsx src/scripts/commit-buffer.ts",
    "reveal:day": "tsx src/scripts/reveal.ts",
    "reveal:buffer": "node dist/scripts/reveal-buffer.js",
    "reveal:buffer:dev": "tsx src/scripts/reveal-buffer.ts",
    "indexer": "tsx src/scripts/indexer.ts",
    "indexer:once": "tsx src/scripts/indexer.ts --once",
    "indexer:start": "node dist/scripts/indexer.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@wordlelo/contracts": "workspace:*",
    "@wordlelo/core": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.0",
    "postgres": "^3.4.5",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
