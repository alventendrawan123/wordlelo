{
  "name": "@wordlelo/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Wordlelo shared game logic — authoritative 2-pass scoring + hard-mode rules (no word lists, no answers)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
